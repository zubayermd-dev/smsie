server:
  port: ":8080"
  mode: "debug" # debug, release

database:
  driver: "sqlite" # sqlite, mysql
  dsn: "ivy.db"

serial:
  scan_interval: 5s
  exclude_ports:
    # - "COM1"
  init_at_commands:
    - "ATE0"
    - "AT+COPS=3,2"
    - "AT+CMGF=0" # PDU mode
    - "AT+CNMI=2,1,0,0,0" # New SMS notification to TE

calling:
  stun_servers:
    - "stun:stun.l.google.com:19302"
  udp_port_min: 40000
  udp_port_max: 40100
  sip:
    register_expires: 300
    local_host: "" # optional, auto-detect if empty
    local_port: 5060 # base listener port, auto-assigns upward when a modem has no fixed port yet
    rtp_bind_ip: "0.0.0.0"
    rtp_port_min: 30000
    rtp_port_max: 30010
    invite_timeout_sec: 30
    dtmf_method: "info"
    dtmf_duration_ms: 160
  audio:
    device_keyword: "AC Interface"
    output_device_name: ""
    sample_rate: 8000
    channels: 1
    bits_per_sample: 16
    capture_chunk_ms: 40
    playback_chunk_ms: 100

log:
  level: "info" # debug, info, warn, error
